# ⚕️ HUMAN CHECK - Variables de entorno
# Copiar este archivo como .env y configurar los valores antes de ejecutar

# Producer
PRODUCER_PORT=3000
NODE_ENV=development

# Frontend
FRONTEND_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_COOKIE_NAME=auth_token
NEXT_PUBLIC_AUTH_COOKIE_MAX_AGE=86400

# RabbitMQ - Broker
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_URL=amqp://rabbitmq:5672
RABBITMQ_QUEUE=turnos_queue
RABBITMQ_NOTIFICATIONS_QUEUE=turnos_notifications

# ⚕️ HUMAN CHECK - Credenciales de RabbitMQ
# Cambiar estos valores por defecto antes de ir a producción
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# MongoDB - Persistencia
MONGODB_PORT=27017
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/turnos_db?authSource=admin

# ⚕️ HUMAN CHECK - Credenciales de MongoDB
# Cambiar estos valores por defecto antes de ir a producción
MONGO_USER=admin
MONGO_PASS=admin123

# Consumer - Scheduler
SCHEDULER_INTERVAL_MS=15000
CONSULTORIOS_TOTAL=5

# ⚕️ HUMAN CHECK - Clave secreta para tokens HMAC de autenticación
# Cambiar este valor por uno seguro y aleatorio antes de ir a producción
AUTH_TOKEN_SECRET=dev-auth-secret

