{
    "name": "backend-producer",
    "version": "0.0.1",
    "description": "Microservicio Producer para gestión de turnos",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:acceptance": "cucumber-js"
    },
    "dependencies": {
        "@nestjs/common": "^10.4.22",
        "@nestjs/config": "^3.3.0",
        "@nestjs/core": "^10.4.22",
        "@nestjs/microservices": "^10.4.22",
        "@nestjs/mongoose": "^11.0.4",
        "@nestjs/platform-express": "^10.4.22",
        "@nestjs/platform-socket.io": "^10.4.22",
        "@nestjs/swagger": "^8.1.1",
        "@nestjs/websockets": "^10.4.22",
        "amqp-connection-manager": "^4.1.15",
        "amqplib": "^0.10.9",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.4",
        "mongoose": "^9.2.4",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "socket.io": "^4.8.3"
    },
    "devDependencies": {
        "@cucumber/cucumber": "^12.7.0",
        "@nestjs/cli": "^10.4.9",
        "@nestjs/schematics": "^10.2.3",
        "@nestjs/testing": "^10.4.22",
        "@types/express": "^4.17.25",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.19.37",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-prettier": "^5.5.5",
        "jest": "^29.7.0",
        "multer": "2.1.0",
        "prettier": "^3.8.1",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.4",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "webpack": "5.105.2"
    }
}
